AddKeysToAgent yes

# Narval login alias (direct to narval1).
Host narval
	HostName narval1.alliancecan.ca
	User 	 $USER
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlMaster auto
    ControlPersist 600m
# Bitbucket over SSH uses the git user.
Host bitbucket
	HostName bitbucket.org
	User git
# Rorqual login alias.
Host rorqual
	HostName rorqual.alliancecan.ca
	User 	 $USER
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlMaster auto
    ControlPersist 600m
# Nibi login alias.
Host nibi
	HostName nibi.alliancecan.ca
	User 	 $USER
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlMaster auto
    ControlPersist 600m
# Rorqual node 1 with a custom identity file.
Host rorqual1
	HostName rorqual1.alliancecan.ca
	User 	 $USER
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlMaster auto
    ControlPersist 600m
    IdentityFile ~/.ssh/id_ed25519_github2
# Rorqual node 2.
Host rorqual2
	HostName rorqual2.alliancecan.ca
	User 	 $USER
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlMaster auto
    ControlPersist 600m
# Fir login alias.
Host fir
	HostName fir.alliancecan.ca
	User 	 $USER
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlMaster auto
    ControlPersist 600m
# Reach Narval through rorqual as a jump host.
Host narvaldown
	HostName narval.alliancecan.ca
	ProxyJump rorqual
	User 	 $USER
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlMaster auto
    ControlPersist 600m
